---
---
<div id="aportar-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl mx-4 relative overflow-hidden" style="height: 85vh;">

    <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100">
      <div>
        <h2 class="text-sm font-bold text-gray-900">Aportar material</h2>
        <p id="modal-materia-label" class="text-xs text-gray-400"></p>
      </div>
      <button id="cerrar-modal" class="text-gray-400 hover:text-gray-700 transition-colors p-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <iframe
      src="https://docs.google.com/forms/d/e/1FAIpQLSc4cu1whJofM7Y2IeVpCyuHFWzklYmJL--RDy1XwDLBTTYWXg/viewform?embedded=true"
      width="100%"
      height="100%"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
      style="display:block;"
    >
      Cargando…
    </iframe>

  </div>
</div>

<script>
  const modal = document.getElementById('aportar-modal');
  const cerrar = document.getElementById('cerrar-modal');
  const labelMateria = document.getElementById('modal-materia-label');

  document.addEventListener('abrir-modal-aportar', (e: any) => {
    const materia = e.detail.materia || '';
    const semestre = e.detail.semestre || '';
    if (labelMateria) labelMateria.textContent = `${materia} · Semestre ${semestre}`;
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
  });

  cerrar?.addEventListener('click', () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
  });
</script>
