---
import { driveLinks } from '../data/driveLinks.js';

interface Props {
  titulo: string;
  descripcion: string;
  icono?: string;
  badge?: string;
}

const { titulo, descripcion, icono = 'folder', badge } = Astro.props;

// Obtener el enlace centralizado si existe
const driveUrl = driveLinks[titulo] || '';
const isActive = driveUrl !== '';

// URL del formulario de Google para colaborar
const formUrl = "https://docs.google.com/forms/d/e/1FAIpQLSeHMDuXRaP0Sbtz7nTnw9wXbWO9KD2s76qGtqps3enAL4-IcA/viewform?usp=publish-editor";

const iconMap: Record<string, string> = {
  folder: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />`,
  book: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />`,
  cpu: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z" />`,
  signal: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 15.75l2.25-2.25L7.5 15.75l2.25-2.25L12 15.75l2.25-2.25L16.5 15.75l2.25-2.25L21 15.75M3 9l2.25 2.25L7.5 9l2.25 2.25L12 9l2.25 2.25L16.5 9l2.25 2.25L21 9" />`,
  chart: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />`,
  document: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />`,
  wrench: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />`,
};

const svgPath = iconMap[icono] || iconMap['folder'];
---

<div class="glass-card rounded-2xl flex flex-col overflow-hidden group interactive-card">
  
  <!-- Card Header -->
  <div class="relative p-6 flex items-start justify-between bg-gradient-to-br from-slate-900/80 to-slate-900/20 border-b border-white/5">
    <div class="w-12 h-12 bg-white/5 rounded-xl border border-white/10 flex items-center justify-center group-hover:bg-sky-500/10 group-hover:border-sky-500/30 transition-colors duration-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <Fragment set:html={svgPath} />
      </svg>
    </div>
    
    {isActive ? (
      <span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-[10px] font-extrabold px-2.5 py-1 rounded-full uppercase tracking-wider">
        Activo
      </span>
    ) : (
      <span class="bg-sky-500/5 text-sky-400 border border-sky-500/15 text-[10px] font-semibold px-2.5 py-1 rounded-full uppercase tracking-wider">
        Colaborativo
      </span>
    )}
    
    {badge && (
      <span class="absolute top-2 right-2 bg-sky-500 text-white text-[9px] font-black px-2 py-0.5 rounded-md uppercase">{badge}</span>
    )}
  </div>

  <!-- Card Body -->
  <div class="p-6 flex flex-col flex-1">
    <h3 class="text-white font-bold text-lg leading-tight mb-2 group-hover:text-sky-400 transition-colors duration-300">{titulo}</h3>
    <p class="text-slate-400 text-sm leading-relaxed flex-1">{descripcion}</p>
  </div>

  <!-- Card Footer / CTA -->
  <div class="px-6 pb-6">
    {isActive ? (
      <a
        href={driveUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full bg-gradient-to-r from-sky-500 to-unexpo-blue hover:from-sky-400 hover:to-unexpo-blue-light text-white font-bold text-sm py-3 px-4 rounded-xl transition-all duration-300 shadow-md shadow-sky-500/10 hover:shadow-lg hover:shadow-sky-500/20 active:scale-[0.98]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Descargar Recursos ↗
      </a>
    ) : (
      <a
        href={formUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full bg-white/5 hover:bg-white/10 text-slate-300 hover:text-white font-semibold text-sm py-3 px-4 rounded-xl border border-white/10 hover:border-white/20 transition-all duration-300 active:scale-[0.98]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Aportar Material ↗
      </a>
    )}
  </div>

</div>
