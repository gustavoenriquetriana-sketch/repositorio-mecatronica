---
import { Image } from 'astro:assets';

interface Props {
  titulo: string;
  subtitulo: string;
  descripcionCorta: string;
  urlFotoPortada?: string | any;
  href?: string;
}

const { titulo, subtitulo, descripcionCorta, urlFotoPortada, href = '#' } = Astro.props;
---

<div class="glass-card rounded-2xl flex flex-col overflow-hidden group interactive-card">

  <!-- Portada / Imagen -->
  <div class="relative w-full h-56 overflow-hidden bg-slate-900 border-b border-white/5">
    {urlFotoPortada ? (
      <Image 
        src={urlFotoPortada} 
        alt={titulo} 
        inferSize={typeof urlFotoPortada === 'string'}
        class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" 
      />
    ) : (
      <!-- Fallback visual de mecatrónica premium -->
      <div class="absolute inset-0 bg-slate-950 flex items-center justify-center text-5xl">
        📷
      </div>
    )}
    
    <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 to-transparent"></div>
    
    <div class="absolute bottom-4 left-4">
      <span class="bg-slate-950/60 backdrop-blur-md text-sky-400 text-[10px] font-extrabold px-3 py-1 rounded-full border border-sky-500/20 shadow-sm uppercase tracking-wider">
        {subtitulo}
      </span>
    </div>
  </div>

  <!-- Cuerpo -->
  <div class="p-6 flex flex-col flex-1 gap-5">
    <div>
      <h3 class="text-white font-extrabold text-lg leading-tight group-hover:text-sky-400 transition-colors duration-300">
        {titulo}
      </h3>
      <p class="text-slate-400 text-sm leading-relaxed mt-2.5 line-clamp-3">{descripcionCorta}</p>
    </div>

    <!-- Botón -->
    <a
      href={href}
      class="mt-auto flex items-center justify-center gap-2 w-full bg-gradient-to-r from-sky-500 to-unexpo-blue hover:from-sky-400 hover:to-unexpo-blue-light text-white font-bold text-sm py-3 px-4 rounded-xl transition-all duration-300 shadow-md shadow-sky-500/10 hover:shadow-lg hover:shadow-sky-500/20 active:scale-[0.98]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
      </svg>
      Explorar Archivo ✨
    </a>
  </div>

</div>
