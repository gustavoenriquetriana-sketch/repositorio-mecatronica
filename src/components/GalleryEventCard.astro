---
import { Image } from 'astro:assets';

interface Props {
  titulo: string;
  subtitulo: string;
  descripcionCorta: string;
  urlFotoPortada?: string | any;
  href?: string;
}

const { titulo, subtitulo, descripcionCorta, urlFotoPortada, href = '#' } = Astro.props;
---

<div class="bg-white border border-gray-200 rounded-2xl overflow-hidden hover:border-gray-300 hover:shadow-sm transition-all flex flex-col group">

  <!-- Portada / Imagen -->
  <div class="relative w-full h-56 overflow-hidden bg-gray-100 border-b border-gray-100">
    {urlFotoPortada ? (
      <Image 
        src={urlFotoPortada} 
        alt={titulo} 
        inferSize={typeof urlFotoPortada === 'string'}
        class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" 
      />
    ) : (
      <!-- Fallback visual de mecatrónica premium -->
      <div class="absolute inset-0 bg-slate-950 flex items-center justify-center text-5xl">
        📷
      </div>
    )}
    
    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
  </div>

  <!-- Cuerpo -->
  <div class="p-6 flex flex-col flex-1 gap-5">
    <div>
      <h3 class="text-gray-900 font-extrabold text-lg leading-tight">
        {titulo}
      </h3>
    </div>

    <!-- Botón -->
    <a
      href={href}
      class="mt-auto flex items-center justify-center gap-2 w-full bg-gray-900 hover:bg-gray-700 text-white font-bold text-sm py-3 px-4 rounded-xl transition-all active:scale-[0.98]"
    >
      Explorar Archivo ✨
    </a>
  </div>

</div>
