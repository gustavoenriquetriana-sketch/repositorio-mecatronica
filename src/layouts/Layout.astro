---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Repositorio académico de guías, proyectos y software para estudiantes de Ingeniería Mecatrónica de la UNEXPO Guarenas.' } = Astro.props;
---

<!doctype html>
<html lang="es" class="h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph / Redes Sociales / WhatsApp -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/favicon.svg" />

    <!-- Google Fonts: Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    
    <title>{title} | Repositorio Mecatrónica UNEXPO</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-full flex flex-col bg-slate-950 text-slate-100 antialiased selection:bg-sky-500 selection:text-white">

    <!-- NAVBAR -->
    <header class="glass-nav">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 sm:h-20">

          <!-- Logo / Brand -->
          <a href="/" class="flex items-center gap-3 group">
            <div class="w-10 h-10 bg-gradient-to-br from-sky-500 to-unexpo-blue rounded-xl flex items-center justify-center shadow-md shadow-sky-500/10 group-hover:scale-105 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5.5 h-5.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-white font-extrabold text-base sm:text-lg tracking-tight leading-none group-hover:text-sky-400 transition-colors">
                Mecatrónica
              </span>
              <span class="text-sky-400 text-xs font-semibold tracking-wide mt-0.5">UNEXPO Guarenas</span>
            </div>
          </a>

          <!-- Nav Links - Desktop -->
          <div class="hidden md:flex items-center gap-1.5">
            <a href="/" class="text-slate-300 hover:text-white hover:bg-white/5 px-4 py-2 rounded-xl text-sm font-semibold transition-all">Inicio</a>
            <a href="/semestres" class="text-slate-300 hover:text-white hover:bg-white/5 px-4 py-2 rounded-xl text-sm font-semibold transition-all">Semestres</a>
            <a href="/software" class="text-slate-300 hover:text-white hover:bg-white/5 px-4 py-2 rounded-xl text-sm font-semibold transition-all">Software</a>
            <a href="/galeria" class="text-slate-300 hover:text-white hover:bg-white/5 px-4 py-2 rounded-xl text-sm font-semibold transition-all">Galería</a>
            <a href="/documentos" class="text-slate-300 hover:text-white hover:bg-white/5 px-4 py-2 rounded-xl text-sm font-semibold transition-all">Documentos</a>
          </div>

          <!-- Mobile menu button -->
          <button id="menu-toggle" class="md:hidden text-slate-300 hover:text-white p-2 rounded-xl hover:bg-white/5 transition-all" aria-label="Abrir menú">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <div class="flex flex-col gap-1.5 pt-2 border-t border-white/10">
            <a href="/" class="text-slate-300 hover:text-white hover:bg-white/5 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all">Inicio</a>
            <a href="/semestres" class="text-slate-300 hover:text-white hover:bg-white/5 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all">Semestres</a>
            <a href="/software" class="text-slate-300 hover:text-white hover:bg-white/5 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all">Software</a>
            <a href="/galeria" class="text-slate-300 hover:text-white hover:bg-white/5 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all">Galería</a>
            <a href="/documentos" class="text-slate-300 hover:text-white hover:bg-white/5 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all">Documentos</a>
          </div>
        </div>
      </nav>
    </header>

    <!-- MAIN CONTENT -->
    <main class="flex-1 flex flex-col relative z-10">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="glass-footer mt-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 items-center gap-8 border-b border-white/5 pb-8 mb-8 text-center md:text-left">
          
          <div class="flex items-center gap-3 justify-center md:justify-start">
            <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center border border-white/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
            <div>
              <p class="font-extrabold text-sm text-white">Repositorio Académico de Mecatrónica</p>
              <p class="text-slate-400 text-xs">UNEXPO Núcleo Guarenas &bull; Venezuela</p>
            </div>
          </div>

          <div class="text-slate-400 text-sm text-center">
            &copy; {new Date().getFullYear()} Repositorio Estudiantil. Todos los derechos reservados.
            <p class="text-xs text-slate-500 mt-1">Vicerrectorado Luis Caballero Mejías</p>
          </div>

          <div class="flex gap-4 justify-center md:justify-end text-sm">
            <a href="/" class="text-slate-400 hover:text-sky-400 transition-colors">Inicio</a>
            <a href="/semestres" class="text-slate-400 hover:text-sky-400 transition-colors">Semestres</a>
            <a href="/documentos" class="text-slate-400 hover:text-sky-400 transition-colors">Documentos</a>
          </div>

        </div>

        <div class="text-center">
          <p class="text-[10px] text-slate-600 uppercase tracking-widest leading-relaxed max-w-xl mx-auto">
            Este portal ha sido creado para fines exclusivamente académicos y de apoyo a la comunidad de estudiantes del Núcleo Guarenas de la UNEXPO.
          </p>
        </div>
      </div>
    </footer>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');
        toggle?.addEventListener('click', () => {
          menu?.classList.toggle('hidden');
        });
      });
    </script>

  </body>
</html>
