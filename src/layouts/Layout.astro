---
import "../styles/global.css";
import AportarModal from '../components/AportarModal.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Repositorio académico de guías, proyectos y software para estudiantes de Ingeniería Mecatrónica de la UNEXPO Guarenas.",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Repositorio Mecatrónica UNEXPO</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-full flex flex-col bg-white text-gray-900 antialiased">
    <!-- NAVBAR -->
    <header class="repo-nav">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2.5 group">
            <div
              class="w-8 h-8 bg-gray-900 rounded-lg flex items-center justify-center"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 text-white"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2v-4M9 21H5a2 2 0 01-2-2v-4m0 0h18"
                ></path>
              </svg>
            </div>
            <div>
              <span class="font-bold text-sm text-gray-900 leading-none block"
                >Mecatrónica</span
              >
              <span class="text-xs text-gray-400 leading-none"
                >UNEXPO Guarenas</span
              >
            </div>
          </a>

          <div class="hidden md:flex items-center gap-1">
            <a
              href="/"
              class="text-gray-500 hover:text-gray-900 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors hover:bg-gray-100"
              >Inicio</a
            >
            <a
              href="/semestres"
              class="text-gray-500 hover:text-gray-900 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors hover:bg-gray-100"
              >Semestres</a
            >
            <a
              href="/software"
              class="text-gray-500 hover:text-gray-900 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors hover:bg-gray-100"
              >Software</a
            >
            <a
              href="/galeria"
              class="text-gray-500 hover:text-gray-900 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors hover:bg-gray-100"
              >Galería</a
            >
            <a
              href="/documentos"
              class="text-gray-500 hover:text-gray-900 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors hover:bg-gray-100"
              >Documentos</a
            >
          </div>

          <button
            id="menu-toggle"
            class="md:hidden text-gray-500 hover:text-gray-900 p-2 rounded-lg hover:bg-gray-100 transition-colors"
            aria-label="Abrir menú"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>

        <div id="mobile-menu" class="hidden md:hidden pb-3">
          <div class="flex flex-col gap-1 pt-2 border-t border-gray-100">
            <a
              href="/"
              class="text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg text-sm font-medium transition-colors"
              >Inicio</a
            >
            <a
              href="/semestres"
              class="text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg text-sm font-medium transition-colors"
              >Semestres</a
            >
            <a
              href="/software"
              class="text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg text-sm font-medium transition-colors"
              >Software</a
            >
            <a
              href="/galeria"
              class="text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg text-sm font-medium transition-colors"
              >Galería</a
            >
            <a
              href="/documentos"
              class="text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg text-sm font-medium transition-colors"
              >Documentos</a
            >
          </div>
        </div>
      </nav>
    </header>

    <main class="flex-1 flex flex-col">
      <slot />
    </main>

    <footer class="border-t border-gray-100 mt-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col items-center gap-4">
        
        <div class="flex flex-wrap items-center justify-center gap-4 text-sm">
          <a href="/" class="text-gray-400 hover:text-gray-700 transition-colors">Inicio</a>
          <a href="/semestres" class="text-gray-400 hover:text-gray-700 transition-colors">Semestres</a>
          <a href="/software" class="text-gray-400 hover:text-gray-700 transition-colors">Software</a>
          <a href="/galeria" class="text-gray-400 hover:text-gray-700 transition-colors">Galería</a>
          <a href="/documentos" class="text-gray-400 hover:text-gray-700 transition-colors">Documentos</a>
        </div>

        <p class="text-xs text-gray-400 text-center">
          Mecatrónica UNEXPO Guarenas · © {new Date().getFullYear()} · Hecho por Gustavo Triana
        </p>

      </div>
    </footer>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const toggle = document.getElementById("menu-toggle");
        const menu = document.getElementById("mobile-menu");
        toggle?.addEventListener("click", () => {
          menu?.classList.toggle("hidden");
        });
      });
    </script>
    <AportarModal />
  </body>
</html>
