---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Error 404 - Sistema no encontrado"
  description="La página que buscas no existe en el Repositorio de Mecatrónica UNEXPO Guarenas."
>
  <section class="min-h-[72vh] flex flex-col items-center justify-center text-center px-4 py-20 relative overflow-hidden">
    <div class="absolute inset-0 engineering-grid opacity-30"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-sky-500/10 rounded-full blur-[100px] pointer-events-none"></div>

    <!-- Número 404 gigante -->
    <div class="relative mb-6 select-none z-10">
      <span class="text-[10rem] sm:text-[14rem] font-black text-white/5 leading-none tracking-tighter">
        404
      </span>
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="w-24 h-24 bg-white/5 rounded-3xl border border-white/10 flex items-center justify-center shadow-lg shadow-black/30">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Texto principal -->
    <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-4 z-10">
      ¡Cortocircuito detectado!
    </h1>
    <p class="text-slate-400 text-base sm:text-lg max-w-lg mx-auto leading-relaxed mb-10 z-10">
      Parece que un cable de datos se desconectó. La página o el documento que buscas 
      <strong class="text-white font-bold">no existe en este servidor académico</strong>.
    </p>

    <!-- CTA -->
    <a
      href="/"
      class="inline-flex items-center gap-2 bg-gradient-to-r from-sky-500 to-unexpo-blue hover:from-sky-400 hover:to-unexpo-blue-light text-white font-bold px-8 py-3.5 rounded-xl transition-all duration-300 shadow-md shadow-sky-500/10 hover:shadow-lg hover:shadow-sky-500/25 active:scale-95 text-base z-10"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Volver al Inicio
    </a>

    <!-- Código de error sutil -->
    <p class="text-slate-600 text-xs mt-14 font-mono tracking-widest uppercase z-10">
      Error 404 &bull; Recurso no encontrado &bull; UNEXPO Guarenas
    </p>

  </section>
</Layout>
