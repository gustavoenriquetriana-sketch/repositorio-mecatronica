---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import pensumPreview from '../assets/pensum-preview.png';

const planillas = [
  {
    titulo: 'Planilla de Inscripción',
    tipo: 'PDF',
    color: 'red',
    descripcion: 'Inscripción de sobrecréditos y materias paralelas.',
    url: '/planilla-inscripcion.pdf',
  },
  {
    titulo: 'Solvencia Servicio Comunitario',
    tipo: 'DOCX',
    color: 'blue',
    descripcion: 'Constancia oficial de culminación UNEXPO.',
    url: '/solvencia-servicio-comunitario.docx',
  },
  {
    titulo: 'Formato de Proyecto SC',
    tipo: 'DOC',
    color: 'blue',
    descripcion: 'Estructura metodológica para proyectos comunitarios.',
    url: '/formato-proyecto.doc', // Corrección del bug: extensión .doc real del archivo en /public
  },
  {
    titulo: 'Carta de Aceptación',
    tipo: 'DOCX',
    color: 'blue',
    descripcion: 'Aval firmado por la empresa o comunidad receptora.',
    url: '/carta-aceptacion.docx',
  },
  {
    titulo: 'Diario de Trabajo',
    tipo: 'PDF',
    color: 'red',
    descripcion: 'Formato para el registro semanal de pasantías.',
    url: '/diario-trabajo.pdf',
  },
];
---

<Layout
  title="Documentos Oficiales"
  description="Descarga el pensum de estudios, planillas de servicio comunitario y diarios de trabajo para pasantías de Mecatrónica UNEXPO Guarenas."
>

  <!-- ══════════════════════ HERO CORTO ══════════════════════ -->
  <section class="relative overflow-hidden border-b border-white/5 py-14 bg-slate-950/40">
    <div class="absolute inset-0 engineering-grid opacity-30"></div>
    <div class="absolute -top-10 -right-10 w-72 h-72 bg-sky-500 rounded-full blur-[90px] opacity-10 pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-slate-400 text-xs sm:text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-white font-medium">Documentos Oficiales</span>
      </nav>

      <div class="flex items-center gap-4">
        <div class="w-14 h-14 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center flex-shrink-0 text-sky-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-white">Formatos y Trámites Oficiales</h1>
          <p class="text-slate-400 mt-1.5 text-sm sm:text-base">
            Descarga de planillas de control académico, servicio comunitario y prácticas de pasantías.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-20">

    <!-- ══════════════════════ SECCIÓN 1: PENSUM ══════════════════════ -->
    <section class="relative">
      
      <div class="mb-10 text-center sm:text-left">
        <p class="text-sky-400 font-extrabold text-xs uppercase tracking-widest mb-2">Estructura Curricular Oficial</p>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white">Pensum de Estudios</h2>
      </div>

      <!-- Tarjeta ancha del Pensum -->
      <div class="glass-card rounded-3xl overflow-hidden">
        <div class="flex flex-col lg:flex-row">

          <!-- Lado izquierdo: info + botón -->
          <div class="flex-1 p-8 sm:p-12 flex flex-col justify-center">
            <div class="inline-flex items-center gap-2 bg-sky-500/10 text-sky-400 text-xs font-bold px-3.5 py-1.5 rounded-full w-fit mb-6 border border-sky-500/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
              Documento Oficial &bull; Revisión 2012
            </div>

            <h3 class="text-white font-extrabold text-2xl sm:text-3xl leading-tight mb-4">
              Pensum Oficial de<br/>Ingeniería Mecatrónica
            </h3>
            <p class="text-slate-400 text-sm leading-relaxed mb-8 max-w-md">
              Estructura curricular aprobada por el Consejo Universitario. Contiene el listado de asignaturas teóricas y prácticas, prelaciones de las materias y unidades de crédito correspondientes de primero a décimo semestre.
            </p>

            <a
              href="/pensum-mecatronica.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-gradient-to-r from-sky-500 to-unexpo-blue hover:from-sky-400 hover:to-unexpo-blue-light text-white font-bold px-7 py-3.5 rounded-xl transition-all duration-300 shadow-md shadow-sky-500/10 hover:shadow-sky-500/25 w-fit text-sm"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
              Descargar Plan de Estudios ↗
            </a>
          </div>

          <!-- Lado derecho: Vista previa del pensum -->
          <div class="lg:w-80 xl:w-96 border-t lg:border-t-0 lg:border-l border-white/10 min-h-[300px] overflow-hidden flex bg-slate-900/50">
            <Image src={pensumPreview} alt="Vista previa del Pensum de Ingeniería Mecatrónica UNEXPO" class="w-full h-full object-cover object-top opacity-80 hover:opacity-100 transition-opacity duration-300" />
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════ SECCIÓN 2: PLANILLAS ══════════════════ -->
    <section>
      
      <div class="mb-10 text-center sm:text-left">
        <p class="text-sky-400 font-extrabold text-xs uppercase tracking-widest mb-2">Formatos Descargables</p>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white">
          Planillas Administrativas y de Servicio
        </h2>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">
        {planillas.map(doc => (
          <a
            href={doc.url}
            download
            class="group glass-card rounded-2xl p-5 flex flex-col items-center text-center gap-4 hover:border-sky-500/40 hover:shadow-sky-500/5 hover:-translate-y-1 transition-all duration-300 relative"
          >
            <!-- Ícono estilo documento con badge de tipo -->
            <div class="relative">
              <div class="w-16 h-20 bg-white/5 rounded-lg border border-white/10 flex flex-col items-center justify-end pb-3 transition-colors relative overflow-hidden">
                <!-- Doblez de esquina -->
                <div class="absolute top-0 right-0 w-5 h-5 bg-white/10 group-hover:bg-sky-500/20 transition-colors"
                  style="clip-path: polygon(100% 0, 100% 100%, 0 100%)">
                </div>
                <div class="absolute top-0 right-0 w-5 h-5 bg-slate-950 rounded-bl-md border-b border-l border-white/10"></div>
                <!-- Líneas decorativas de texto "falso" -->
                <div class="w-8 h-1 bg-white/10 rounded mb-1.5"></div>
                <div class="w-10 h-1 bg-white/10 rounded mb-1.5"></div>
                <div class="w-7 h-1 bg-white/10 rounded"></div>
              </div>
              <!-- Badge DOCX / PDF -->
              <span class={`absolute -bottom-2 left-1/2 -translate-x-1/2 text-white text-[9px] font-black px-2 py-0.5 rounded-md tracking-wider ${doc.color === 'red' ? 'bg-red-500/25 text-red-400 border border-red-500/35' : 'bg-sky-500/20 text-sky-400 border border-sky-500/35'}`}>
                {doc.tipo}
              </span>
            </div>

            <!-- Título y descripción -->
            <div class="mt-2 flex-1 flex flex-col justify-between">
              <div>
                <p class="text-slate-200 font-bold text-sm leading-snug group-hover:text-sky-400 transition-colors">{doc.titulo}</p>
                <p class="text-slate-500 text-xs mt-1.5 leading-normal">{doc.descripcion}</p>
              </div>
              
              <!-- Flecha de descarga -->
              <div class="mt-4 flex justify-center text-slate-500 group-hover:text-sky-400 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

  </div>
</Layout>
