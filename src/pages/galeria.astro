---
import Layout from '../layouts/Layout.astro';
import GalleryEventCard from '../components/GalleryEventCard.astro';
import portada2025 from '../assets/feria-2025/Invernadero1.jpg';

const eventos = [
  {
    titulo: 'Feria Mecatrónica 2025',
    subtitulo: 'Exhibición Científica',
    descripcionCorta: 'Muestra pública de proyectos de automatización, sistemas ciberfísicos y prototipos de potencia desarrollados por estudiantes.',
    href: '/galeria/feria-2025',
    urlFotoPortada: portada2025,
  },
  {
    titulo: 'Feria Mecatrónica 2026',
    subtitulo: 'Próximamente',
    descripcionCorta: 'La edición más reciente enfocada en robótica articulada, control distribuido en PLCs e instrumentación mecatrónica avanzada.',
    href: '/galeria/feria-2026',
    urlFotoPortada: undefined,
  },
];

const totalEventos = eventos.length;
---

<Layout
  title="Galería de Innovación"
  description="Archivo Visual Estudiantil — Ferias Mecatrónicas, prototipos técnicos e historia académica de la UNEXPO Guarenas."
>

  <!-- ══════════════════════ HERO ══════════════════════ -->
  <section class="relative overflow-hidden border-b border-gray-100 py-16 sm:py-20 bg-white">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-gray-400 text-xs sm:text-sm mb-6">
        <a href="/" class="hover:text-gray-700 transition-colors">Inicio</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-gray-700 font-medium">Galería</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div>
          <div class="inline-flex items-center gap-2 bg-amber-50 border border-amber-100 px-3 py-1.5 rounded-full text-xs font-semibold text-amber-600 mb-4 select-none">
            Archivo Histórico de Proyectos
          </div>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-black text-gray-900 leading-tight">
            Nuestra Historia<br/>
            <span class="text-blue-600">en Imágenes</span>
          </h1>
          <p class="text-gray-500 text-sm sm:text-base mt-4 max-w-xl">
            Fotos de las Ferias Mecatrónicas y proyectos de estudiantes de la UNEXPO Núcleo Guarenas.
          </p>
        </div>

        <!-- Estadísticas -->
        <div class="flex gap-4 flex-shrink-0">
          <div class="bg-gray-50 border border-gray-200 rounded-xl px-5 py-3 text-center">
            <p class="text-2xl font-bold text-gray-900 leading-none">2</p>
            <p class="text-gray-400 text-xs mt-1 uppercase tracking-wider">Ediciones</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ GRID DE EVENTOS ══════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between gap-4 mb-10 text-center sm:text-left">
      <div>
        <p class="section-label mb-2">Archivo Fotográfico</p>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900">Eventos y Exposiciones</h2>
      </div>
      <p class="text-gray-400 text-xs sm:text-sm">Selecciona una edición para explorar sus proyectos e innovaciones.</p>
    </div>

    <!-- Grid principal: 2 columnas -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      {eventos.map(evento => (
        <GalleryEventCard
          titulo={evento.titulo}
          subtitulo={evento.subtitulo}
          descripcionCorta={evento.descripcionCorta}
          href={evento.href}
          urlFotoPortada={evento.urlFotoPortada}
        />
      ))}
    </div>

    <!-- Banner de Contribuciones -->
    <div class="mt-20 bg-gray-50 border border-gray-200 rounded-xl p-8 sm:p-10 flex flex-col lg:flex-row items-center justify-between gap-8 relative overflow-hidden group">
      
      <div class="flex items-start gap-5">
        <div class="w-14 h-14 bg-white border border-gray-200 rounded-xl flex items-center justify-center flex-shrink-0 text-2xl">
          📤
        </div>
        <div>
          <h3 class="text-gray-900 font-extrabold text-lg sm:text-xl mb-2">¿Deseas contribuir al archivo visual?</h3>
          <p class="text-gray-500 text-sm leading-relaxed max-w-xl">
            Si eres estudiante o egresado del Núcleo Guarenas y conservas material fotográfico de defensas de tesis, laboratorios o ferias de proyectos anteriores, contribuye al legado de nuestra carrera.
          </p>
        </div>
      </div>
      
      <a
        href="https://docs.google.com/forms/d/e/1FAIpQLSeHMDuXRaP0Sbtz7nTnw9wXbWO9KD2s76qGtqps3enAL4-IcA/viewform?usp=publish-editor"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex-shrink-0 inline-flex items-center gap-2 bg-gray-900 hover:bg-gray-700 text-white font-bold px-7 py-3.5 rounded-xl border border-transparent transition-all duration-300 whitespace-nowrap w-full lg:w-auto text-center justify-center active:scale-95 text-sm"
      >
        Aportar Fotografías
        <span class="inline-block group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300">↗</span>
      </a>
    </div>

  </section>

</Layout>
