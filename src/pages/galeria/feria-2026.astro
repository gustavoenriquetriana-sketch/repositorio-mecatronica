---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Feria Mecatrónica 2026" description="Feria Mecatrónica 2026 — Próximamente.">
  <section class="border-b border-gray-100 py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-xs text-gray-400 mb-8">
        <a href="/" class="hover:text-gray-700 transition-colors">Inicio</a>
        <span>›</span>
        <a href="/galeria" class="hover:text-gray-700 transition-colors">Galería</a>
        <span>›</span>
        <span class="text-gray-700 font-medium">Feria 2026</span>
      </nav>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-32 flex flex-col items-center justify-center text-center gap-6">
    <div class="w-16 h-16 bg-amber-50 border border-amber-100 rounded-2xl flex items-center justify-center text-3xl">
      📷
    </div>
    <h1 class="text-3xl font-bold text-gray-900">Feria Mecatrónica 2026</h1>
    <p class="text-gray-400 text-sm max-w-sm leading-relaxed">
      El archivo fotográfico de esta edición estará disponible próximamente. Vuelve después de la feria.
    </p>
    <a href="/galeria" class="inline-flex items-center gap-2 bg-gray-900 hover:bg-gray-700 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors">
      ← Volver a la galería
    </a>
  </section>
</Layout>
