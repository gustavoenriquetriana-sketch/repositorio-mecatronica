---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Inicio"
  description="Repositorio Académico de Mecatrónica UNEXPO Guarenas — Material didáctico, proyectos y software para estudiantes e investigadores."
>

  <!-- HERO -->
  <section class="border-b border-gray-200 py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">

      <p class="section-label mb-4">Ingeniería Mecatrónica · UNEXPO Guarenas</p>

      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight tracking-tight mb-6">
        Repositorio Académico<br/>
        <span class="text-blue-600">de Mecatrónica</span>
      </h1>

      <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mb-10">
        Material de estudio, guías didácticas, prácticas de laboratorio y software especializado
        para la comunidad estudiantil de la
        <strong class="text-gray-700 font-semibold">UNEXPO Núcleo Guarenas</strong>.
      </p>

      <div class="flex flex-wrap gap-3">
        <a href="/semestres" class="btn-primary">
          Explorar Semestres →
        </a>
        <a href="/documentos" class="btn-secondary">
          Documentos Oficiales
        </a>
      </div>
    </div>
  </section>

  <!-- SECCIONES PRINCIPALES -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">

    <div class="mb-10">
      <p class="section-label mb-2">Organización del Repositorio</p>
      <h2 class="text-2xl font-bold text-gray-900">Secciones Principales</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

      <a href="/semestres" class="repo-card p-6 flex flex-col gap-4 group">
        <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0118 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 text-sm mb-1 group-hover:text-blue-600 transition-colors">Directorios por Semestre</h3>
          <p class="text-gray-400 text-xs leading-relaxed">Asignaturas del plan de estudios, del 1° al 10° semestre.</p>
        </div>
      </a>

      <a href="/software" class="repo-card p-6 flex flex-col gap-4 group">
        <div class="w-10 h-10 bg-gray-50 rounded-lg flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3" />
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 text-sm mb-1 group-hover:text-blue-600 transition-colors">Bóveda de Software</h3>
          <p class="text-gray-400 text-xs leading-relaxed">SolidWorks, MATLAB, Proteus, FluidSIM y TIA Portal.</p>
        </div>
      </a>

      <a href="/galeria" class="repo-card p-6 flex flex-col gap-4 group">
        <div class="w-10 h-10 bg-gray-50 rounded-lg flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 text-sm mb-1 group-hover:text-blue-600 transition-colors">Archivo de Innovación</h3>
          <p class="text-gray-400 text-xs leading-relaxed">Registro fotográfico de las Ferias Mecatrónicas.</p>
        </div>
      </a>

      <a href="/documentos" class="repo-card p-6 flex flex-col gap-4 group">
        <div class="w-10 h-10 bg-gray-50 rounded-lg flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 text-sm mb-1 group-hover:text-blue-600 transition-colors">Trámites y Documentos</h3>
          <p class="text-gray-400 text-xs leading-relaxed">Planillas de sobrecréditos, servicio comunitario y pasantías.</p>
        </div>
      </a>

    </div>
  </section>

  <!-- DOCUMENTACIÓN DESTACADA -->
  <section class="border-t border-gray-200 bg-gray-50 py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="mb-10">
        <p class="section-label mb-2">Archivos Rápidos</p>
        <h2 class="text-2xl font-bold text-gray-900">Documentación Destacada</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <a href="/pensum-mecatronica.pdf" target="_blank" rel="noopener noreferrer"
          class="repo-card p-5 flex items-center gap-4 group">
          <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0118 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Estructura curricular oficial</p>
            <h3 class="text-gray-900 font-semibold text-sm group-hover:text-blue-600 transition-colors">Pensum de Estudios (2012)</h3>
            <p class="text-gray-400 text-xs mt-0.5">Todas las asignaturas y prelaciones en PDF.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 group-hover:text-blue-600 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </a>

        <a href="/diario-trabajo.pdf" target="_blank" rel="noopener noreferrer"
          class="repo-card p-5 flex items-center gap-4 group">
          <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-gray-400 uppercase tracking-wide mb-0.5">Control de pasantía académica</p>
            <h3 class="text-gray-900 font-semibold text-sm group-hover:text-blue-600 transition-colors">Diario de Trabajo de Pasantías</h3>
            <p class="text-gray-400 text-xs mt-0.5">Formato PDF para el registro semanal de actividades.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-300 group-hover:text-blue-600 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </a>

      </div>
    </div>
  </section>

</Layout>
