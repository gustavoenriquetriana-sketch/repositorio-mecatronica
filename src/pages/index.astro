---
import Layout from '../layouts/Layout.astro';

const romanos: Record<number, string> = {
  1: 'I', 2: 'II', 3: 'III', 4: 'IV', 5: 'V',
  6: 'VI', 7: 'VII', 8: 'VIII', 9: 'IX', 10: 'X',
};

const semestres = Array.from({ length: 10 }, (_, i) => ({
  num: i + 1,
  romano: romanos[i + 1],
  href: `/semestres/${i + 1}`,
}));
---

<Layout
  title="Inicio"
  description="Repositorio Académico de Mecatrónica UNEXPO Guarenas — Material didáctico, proyectos y software para estudiantes e investigadores."
>

  <!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
  <section class="relative overflow-hidden border-b border-white/5 py-24 sm:py-32 lg:py-40">
    
    <!-- Cuadrícula de ingeniería técnica interactiva en fondo -->
    <div class="absolute inset-0 engineering-grid opacity-60"></div>
    
    <!-- Luces ambientales de fondo (Ambient Glow) -->
    <div class="absolute top-1/4 -right-40 w-[500px] h-[500px] bg-sky-500 rounded-full blur-[130px] opacity-15 pointer-events-none"></div>
    <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] bg-unexpo-blue rounded-full blur-[130px] opacity-10 pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Badge Académico -->
      <div class="inline-flex items-center gap-2 bg-sky-500/10 border border-sky-500/30 backdrop-blur-md px-4 py-2 rounded-full text-xs font-semibold text-sky-400 mb-8 select-none">
        <span class="w-2.5 h-2.5 bg-sky-400 rounded-full animate-pulse"></span>
        Ingeniería Mecatrónica &bull; Vicerrectorado Luis Caballero Mejías
      </div>

      <!-- Título Principal -->
      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight mb-8">
        Repositorio<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 via-sky-300 to-cyan-200">
          Académico
        </span><br/>
        <span class="text-white/95">de Mecatrónica</span>
      </h1>

      <!-- Subtítulo Profesional -->
      <p class="text-slate-300 text-lg sm:text-xl leading-relaxed max-w-2xl mb-12">
        El archivo digital de material de estudio, guías didácticas, prácticas de laboratorio y software especializado para la comunidad de estudiantes y docentes de la
        <strong class="text-white font-bold">UNEXPO Núcleo Guarenas</strong>.
      </p>

      <!-- Botones de Acción Rápida -->
      <div class="flex flex-wrap gap-4">
        <a href="/semestres"
          class="inline-flex items-center gap-2 bg-gradient-to-r from-sky-500 to-unexpo-blue hover:from-sky-400 hover:to-unexpo-blue-light text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 shadow-lg shadow-sky-500/10 hover:shadow-sky-500/25 active:scale-95 text-base">
          Explorar los Semestres &rarr;
        </a>
        <a href="/documentos"
          class="inline-flex items-center gap-2 bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 text-white font-semibold px-8 py-4 rounded-2xl transition-all duration-300 text-base backdrop-blur-md">
          Documentos Oficiales
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════ SECCIONES CLAVE ════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24">

    <div class="mb-16 text-center md:text-left">
      <p class="text-sky-400 font-extrabold text-xs uppercase tracking-widest mb-3">Organización del Repositorio</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white">Secciones Principales</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <!-- 1. Semestres -->
      <a href="/semestres" class="group glass-card rounded-2xl p-8 flex flex-col items-center gap-5 hover:border-sky-500/40 hover:shadow-sky-500/5 hover:-translate-y-1 text-center transition-all duration-300">
        <div class="w-16 h-16 bg-white/5 group-hover:bg-sky-500 group-hover:shadow-lg group-hover:shadow-sky-500/25 rounded-2xl flex items-center justify-center border border-white/10 group-hover:border-transparent transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-sky-400 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <div>
          <h3 class="font-extrabold text-white text-lg group-hover:text-sky-400 transition-colors mb-2">Directorios por Semestre</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Las asignaturas oficiales del plan de estudios, ordenadas de 1° a 10° semestre.</p>
        </div>
      </a>

      <!-- 2. Software -->
      <a href="/software" class="group glass-card rounded-2xl p-8 flex flex-col items-center gap-5 hover:border-emerald-500/40 hover:shadow-emerald-500/5 hover:-translate-y-1 text-center transition-all duration-300">
        <div class="w-16 h-16 bg-white/5 group-hover:bg-emerald-500 group-hover:shadow-lg group-hover:shadow-emerald-500/25 rounded-2xl flex items-center justify-center border border-white/10 group-hover:border-transparent transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-emerald-400 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3" />
          </svg>
        </div>
        <div>
          <h3 class="font-extrabold text-white text-lg group-hover:text-emerald-400 transition-colors mb-2">Bóveda de Software</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Enlaces e instrucciones para SolidWorks, MATLAB, Proteus, FluidSIM y TIA Portal.</p>
        </div>
      </a>

      <!-- 3. Galería -->
      <a href="/galeria" class="group glass-card rounded-2xl p-8 flex flex-col items-center gap-5 hover:border-amber-500/40 hover:shadow-amber-500/5 hover:-translate-y-1 text-center transition-all duration-300">
        <div class="w-16 h-16 bg-white/5 group-hover:bg-amber-500 group-hover:shadow-lg group-hover:shadow-amber-500/25 rounded-2xl flex items-center justify-center border border-white/10 group-hover:border-transparent transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-amber-400 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
          </svg>
        </div>
        <div>
          <h3 class="font-extrabold text-white text-lg group-hover:text-amber-400 transition-colors mb-2">Archivo de Innovación</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Registro fotográfico e histórico de los proyectos presentados en las Ferias Mecatrónicas.</p>
        </div>
      </a>

      <!-- 4. Documentos -->
      <a href="/documentos" class="group glass-card rounded-2xl p-8 flex flex-col items-center gap-5 hover:border-violet-500/40 hover:shadow-violet-500/5 hover:-translate-y-1 text-center transition-all duration-300">
        <div class="w-16 h-16 bg-white/5 group-hover:bg-violet-500 group-hover:shadow-lg group-hover:shadow-violet-500/25 rounded-2xl flex items-center justify-center border border-white/10 group-hover:border-transparent transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-violet-400 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <div>
          <h3 class="font-extrabold text-white text-lg group-hover:text-violet-400 transition-colors mb-2">Trámites y Documentos</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Descarga de planillas oficiales para sobrecréditos, servicio comunitario y pasantías.</p>
        </div>
      </a>

    </div>
  </section>

  <!-- ═══════════════════════════════ RECURSOS DESTACADOS ════════════════════════════ -->
  <section class="relative bg-slate-950/40 border-y border-white/5 py-24 overflow-hidden">
    
    <div class="absolute inset-0 engineering-grid opacity-30"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-sky-500/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="mb-12 text-center md:text-left">
        <p class="text-sky-400 font-extrabold text-xs uppercase tracking-widest mb-3">Archivos Rápidos</p>
        <h2 class="text-3xl font-extrabold text-white">Documentación Destacada</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- Descargar Pensum de Estudios -->
        <a href="/pensum-mecatronica.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="group glass-card rounded-2xl p-6 flex items-center gap-6 border-white/10 hover:border-sky-500/30 hover:bg-slate-900/60 hover:-translate-y-0.5 transition-all duration-300">
          <div class="w-14 h-14 bg-white/5 rounded-2xl flex items-center justify-center flex-shrink-0 text-sky-400 border border-white/10 group-hover:bg-sky-500 group-hover:text-white transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-[10px] text-slate-500 font-extrabold uppercase tracking-widest mb-1">Estructura curricular oficial</p>
            <h3 class="text-white font-bold text-lg group-hover:text-sky-400 transition-colors">Pensum de Estudios (2012)</h3>
            <p class="text-slate-400 text-sm mt-0.5">Todas las asignaturas y prelaciones en un cómodo documento PDF.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-500 group-hover:text-sky-400 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </a>

        <!-- Diario de Trabajo (Internships / Pasantías) -->
        <a href="/diario-trabajo.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="group glass-card rounded-2xl p-6 flex items-center gap-6 border-white/10 hover:border-sky-500/30 hover:bg-slate-900/60 hover:-translate-y-0.5 transition-all duration-300">
          <div class="w-14 h-14 bg-white/5 rounded-2xl flex items-center justify-center flex-shrink-0 text-sky-400 border border-white/10 group-hover:bg-sky-500 group-hover:text-white transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-[10px] text-slate-500 font-extrabold uppercase tracking-widest mb-1">Control de pasantía académica</p>
            <h3 class="text-white font-bold text-lg group-hover:text-sky-400 transition-colors">Diario de Trabajo de Pasantías</h3>
            <p class="text-slate-400 text-sm mt-0.5">Formato oficial en PDF para el registro de actividades semanales.</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-500 group-hover:text-sky-400 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
        </a>

      </div>
    </div>
  </section>

</Layout>
