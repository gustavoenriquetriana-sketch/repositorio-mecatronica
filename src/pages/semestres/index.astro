---
import Layout from '../../layouts/Layout.astro';

const romanos: Record<number, string> = {
  1: 'I', 2: 'II', 3: 'III', 4: 'IV', 5: 'V',
  6: 'VI', 7: 'VII', 8: 'VIII', 9: 'IX', 10: 'X',
};

const semestres = Array.from({ length: 10 }, (_, i) => ({
  num: i + 1,
  romano: romanos[i + 1],
  href: `/semestres/${i + 1}`,
}));
---

<Layout
  title="Semestres"
  description="Directorio de los 10 semestres de Ingeniería Mecatrónica UNEXPO Guarenas."
>

  <!-- HERO -->
  <section class="border-b border-gray-200 py-14 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-gray-400 text-xs mb-8">
        <a href="/" class="hover:text-gray-700 transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-gray-700 font-medium">Semestres</span>
      </nav>

      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <p class="section-label mb-3">Plan de Estudios 2012</p>
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">Directorio de Asignaturas</h1>
          <p class="text-gray-500 mt-2 text-sm max-w-xl">
            Selecciona un semestre para acceder al material didáctico, guías y prácticas.
          </p>
        </div>
        <div class="text-right">
          <p class="text-2xl font-bold text-gray-900">10</p>
          <p class="text-xs text-gray-400 uppercase tracking-wider">Semestres</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOQUES ACADÉMICOS -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-14">
      <div class="repo-card p-6">
        <p class="section-label mb-2">Etapa I · Sem. 1–3</p>
        <h3 class="font-semibold text-gray-900 text-sm mb-2">Fundación Científica</h3>
        <p class="text-gray-400 text-xs leading-relaxed">
          Ciencias físicas, matemáticas fundamentales, cálculo y lenguaje técnico.
        </p>
      </div>
      <div class="repo-card p-6">
        <p class="section-label mb-2">Etapa II · Sem. 4–7</p>
        <h3 class="font-semibold text-gray-900 text-sm mb-2">Ciencias de la Ingeniería</h3>
        <p class="text-gray-400 text-xs leading-relaxed">
          Mecánica, circuitos eléctricos, electrónica y sistemas lógicos digitales.
        </p>
      </div>
      <div class="repo-card p-6">
        <p class="section-label mb-2">Etapa III · Sem. 8–10</p>
        <h3 class="font-semibold text-gray-900 text-sm mb-2">Ingeniería Aplicada</h3>
        <p class="text-gray-400 text-xs leading-relaxed">
          Control automático, automatización industrial, redes y proyectos finales.
        </p>
      </div>
    </div>

    <!-- GRID DE SEMESTRES -->
    <div class="border-t border-gray-100 pt-12">
      <div class="flex items-end justify-between mb-8">
        <h2 class="text-xl font-bold text-gray-900">Semestres del Plan de Estudios</h2>
        <span class="text-gray-400 text-xs hidden sm:block">Ingeniería Mecatrónica · Núcleo Guarenas</span>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
        {semestres.map(s => (
          <a
            href={s.href}
            class="repo-card p-5 flex flex-col items-center gap-3 text-center group"
          >
            <div class="w-12 h-12 bg-gray-50 group-hover:bg-blue-50 border border-gray-200 group-hover:border-blue-200 rounded-xl flex items-center justify-center transition-colors duration-200">
              <span class="text-lg font-bold text-gray-700 group-hover:text-blue-600 transition-colors">
                {s.romano}
              </span>
            </div>
            <div>
              <p class="font-medium text-gray-800 group-hover:text-blue-600 transition-colors text-sm">
                Semestre {s.num}
              </p>
              <p class="text-gray-400 text-xs mt-0.5">Ver materias →</p>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- NOTA INFORMATIVA -->
    <div class="mt-12 border border-blue-100 bg-blue-50 rounded-xl p-5">
      <p class="text-blue-800 text-sm leading-relaxed">
        <strong class="font-semibold">Nota:</strong> Cada semestre contiene las materias del
        <strong>Pensum Oficial de Ingeniería Mecatrónica (Revisión 2012)</strong>. Si una asignatura
        no tiene material disponible, puedes usar el botón <strong>"Aportar"</strong> para contribuir
        con guías, exámenes y apuntes.
      </p>
    </div>

  </section>

</Layout>
