---
import Layout from '../../layouts/Layout.astro';

const romanos: Record<number, string> = {
  1: 'I', 2: 'II', 3: 'III', 4: 'IV', 5: 'V',
  6: 'VI', 7: 'VII', 8: 'VIII', 9: 'IX', 10: 'X',
};

const semestres = Array.from({ length: 10 }, (_, i) => ({
  num: i + 1,
  romano: romanos[i + 1],
  href: `/semestres/${i + 1}`,
}));
---

<Layout
  title="Semestres"
  description="Directorio de los 10 semestres de Ingeniería Mecatrónica UNEXPO Guarenas. Encuentra recursos educativos organizados para cada asignatura."
>

  <!-- ══════════════════════ HERO ══════════════════════ -->
  <section class="relative overflow-hidden border-b border-white/5 py-16 sm:py-20 bg-slate-950/40">
    <div class="absolute inset-0 engineering-grid opacity-40"></div>
    <div class="absolute -top-10 -right-10 w-80 h-80 bg-sky-500 rounded-full blur-[100px] opacity-10 pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-slate-400 text-xs sm:text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-white font-medium">Semestres</span>
      </nav>

      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 bg-white/5 rounded-2xl border border-white/10 flex items-center justify-center flex-shrink-0 text-sky-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <div>
            <h1 class="text-3xl sm:text-4xl font-black text-white">Directorio de Asignaturas</h1>
            <p class="text-slate-400 mt-1.5 text-sm sm:text-base max-w-xl">
              Selecciona un semestre para acceder al material didáctico digital, guías docentes y prácticas.
            </p>
          </div>
        </div>
        
        <!-- Badge Plan -->
        <div class="bg-white/5 border border-white/10 rounded-2xl px-5 py-3 text-center md:text-right w-fit">
          <p class="text-white font-extrabold text-lg leading-none">Pensum 2012</p>
          <p class="text-sky-400 text-xs font-semibold uppercase tracking-wider mt-1.5">Vigente &bull; UNEXPO</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ ESTRUCTURA ACADÉMICA ══════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Bloques Académicos descriptivos -->
    <div class="mb-14 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="glass-card rounded-2xl p-6 border-sky-500/10">
        <span class="text-xs font-bold text-sky-400 uppercase tracking-widest">Etapa I</span>
        <h3 class="text-white font-bold text-lg mt-2 mb-2">Fundación Científica</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Semestres I al III. Formación integral en ciencias físicas, herramientas matemáticas avanzadas, cálculo fundamental y lenguaje técnico.
        </p>
      </div>
      <div class="glass-card rounded-2xl p-6 border-indigo-500/10">
        <span class="text-xs font-bold text-indigo-400 uppercase tracking-widest">Etapa II</span>
        <h3 class="text-white font-bold text-lg mt-2 mb-2">Ciencias de la Ingeniería</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Semestres IV al VII. Principios mecánicos, análisis de elementos lógicos y circuitos eléctricos. Conexión entre hardware y matemáticas.
        </p>
      </div>
      <div class="glass-card rounded-2xl p-6 border-emerald-500/10">
        <span class="text-xs font-bold text-emerald-400 uppercase tracking-widest">Etapa III</span>
        <h3 class="text-white font-bold text-lg mt-2 mb-2">Ingeniería Aplicada</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Semestres VIII al X. Control automático avanzado, redes de datos industriales, automatización y desarrollo de proyectos integradores finales.
        </p>
      </div>
    </div>

    <div class="border-t border-white/5 pt-12">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-10 text-center sm:text-left">
        <div>
          <p class="text-sky-400 font-extrabold text-xs uppercase tracking-widest mb-2">Acceso a Asignaturas</p>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-white">Semestres del Plan de Estudios</h2>
        </div>
        <span class="text-slate-500 text-xs sm:text-sm font-medium">Ingeniería Mecatrónica &bull; Núcleo Guarenas</span>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">
        {semestres.map(s => (
          <a
            href={s.href}
            class="group glass-card rounded-2xl p-6 flex flex-col items-center gap-4 hover:border-sky-500/40 hover:shadow-sky-500/5 hover:-translate-y-1 transition-all duration-300 text-center cursor-pointer"
          >
            <!-- Número romano -->
            <div class="w-14 h-14 bg-white/5 group-hover:bg-sky-500/10 rounded-2xl border border-white/10 group-hover:border-sky-500/30 flex items-center justify-center transition-all duration-300">
              <span class="text-xl font-black text-sky-400 group-hover:text-sky-300 transition-colors leading-none tracking-tight">
                {s.romano}
              </span>
            </div>

            <div>
              <p class="font-bold text-white group-hover:text-sky-400 transition-colors text-sm sm:text-base">
                Semestre {s.num}
              </p>
              <p class="text-slate-500 text-xs mt-1.5 group-hover:text-sky-400/80 transition-colors">
                Ver materias &rarr;
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Leyenda informativa -->
    <div class="mt-14 bg-sky-500/5 border border-sky-500/10 rounded-2xl p-6 flex items-start gap-4">
      <div class="text-sky-400 flex-shrink-0 mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5.5 h-5.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm leading-none mb-1">Información de Colaboración Estudiantil</h4>
        <p class="text-slate-400 text-sm leading-relaxed mt-1">
          Cada semestre contiene materias del <strong>Pensum Oficial de Ingeniería Mecatrónica (Revisión 2012)</strong>. Si una asignatura no dispone de enlace a Drive activo, puedes presionar en <strong>"Aportar Material"</strong> para subir tus guías, exámenes pasados o apuntes de clase y colaborar con el crecimiento del portal.
        </p>
      </div>
    </div>

  </section>

</Layout>
