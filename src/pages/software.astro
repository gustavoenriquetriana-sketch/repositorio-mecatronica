---
import Layout from '../layouts/Layout.astro';
import SoftwareCard from '../components/SoftwareCard.astro';
import { driveLinks } from '../data/driveLinks.js';

const software = [
  {
    titulo: 'SolidWorks',
    version: 'Versión 2019',
    descripcion: 'Software líder de diseño mecánico en 3D. Modelado de piezas, ensamblajes, simulación de esfuerzos de torsión y análisis cinemático lineal.',
    tipoIcono: 'cad' as const,
  },
  {
    titulo: 'MATLAB',
    version: 'Versión 2017a',
    descripcion: 'Entorno de computación numérica, visualización matricial de datos y programación modular. Indispensable para asignaturas de control y procesamiento de señales.',
    tipoIcono: 'simulacion' as const,
  },
  {
    titulo: 'Proteus',
    version: 'Versión 8.10',
    descripcion: 'Entorno de diseño y simulación interactiva de circuitos electrónicos, microcontroladores y ruteo avanzado de pistas para placas impresas (PCB).',
    tipoIcono: 'simulacion' as const,
  },
  {
    titulo: 'TIA Portal',
    version: 'Versión 15',
    descripcion: 'Plataforma integrada de automatización industrial de Siemens. Programación de controladores lógicos S7-1200/1500, HMI y redes industriales.',
    tipoIcono: 'plc' as const,
  },
  {
    titulo: 'FluidSIM',
    version: 'Versión actual',
    descripcion: 'Simulador dinámico para el diseño y verificación de esquemas de fluidos de potencia (sistemas neumáticos, electroneumáticos e hidráulicos).',
    tipoIcono: 'hidraulica' as const,
  },
];

// Obtener el enlace maestro si existe
const bovedaUrl = driveLinks["BovedaMaestra"] || '';
const hasBoveda = bovedaUrl !== '';

// URL alternativa de aportes
const formUrl = "https://docs.google.com/forms/d/e/1FAIpQLSeHMDuXRaP0Sbtz7nTnw9wXbWO9KD2s76qGtqps3enAL4-IcA/viewform?usp=publish-editor";
---

<Layout
  title="Software y Simuladores"
  description="Herramientas de software especializado, CAD, simulación de circuitos y automatización industrial para estudiantes de Ingeniería Mecatrónica UNEXPO."
>

  <!-- HERO -->
  <section class="border-b border-gray-200 py-14 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-gray-400 text-xs mb-8">
        <a href="/" class="hover:text-gray-700 transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-gray-700 font-medium">Software y Simuladores</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-gray-100 border border-gray-200 rounded-xl flex items-center justify-center flex-shrink-0 text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3" />
            </svg>
          </div>
          <div>
            <h1 class="text-3xl font-bold text-gray-900">Software y Simuladores</h1>
            <p class="text-gray-400 mt-1 text-sm">
              Entornos de cálculo, diseño en 3D, simulación electrónica y programación industrial.
            </p>
          </div>
        </div>

        <div class="text-right flex-shrink-0">
          <p class="text-2xl font-bold text-gray-900">{software.length}</p>
          <p class="text-xs text-gray-400 uppercase tracking-wider">Soportados</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORÍAS -->
  <div class="border-b border-gray-100 bg-white sticky top-14 z-40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <div class="flex flex-wrap items-center gap-2 text-xs">
        <span class="text-gray-400 font-semibold">Líneas de Estudio:</span>
        <span class="bg-violet-50 text-violet-700 border border-violet-100 font-semibold px-3 py-1 rounded-full">CAD / 3D</span>
        <span class="bg-emerald-50 text-emerald-700 border border-emerald-100 font-semibold px-3 py-1 rounded-full">Simulación</span>
        <span class="bg-amber-50 text-amber-700 border border-amber-100 font-semibold px-3 py-1 rounded-full">PLC / SCADA</span>
        <span class="bg-sky-50 text-sky-700 border border-sky-100 font-semibold px-3 py-1 rounded-full">Fluida / Neumática</span>
      </div>
    </div>
  </div>

  <!-- BANNER BÓVEDA MAESTRA -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-7 sm:p-8 flex flex-col lg:flex-row items-center justify-between gap-6">

      <div class="flex items-start gap-4">
        <!-- Ícono de Nube -->
        <div class="w-11 h-11 bg-white border border-gray-200 rounded-lg flex items-center justify-center flex-shrink-0 text-gray-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-1.5">Bóveda Maestra de Recursos de Software</h2>
          <p class="text-gray-500 text-sm leading-relaxed max-w-xl">
            ¿Requieres librerías adicionales, manuales oficiales de simulación o versiones complementarias? Explora el archivo principal del repositorio estudiantil.
          </p>
        </div>
      </div>

      <!-- Call to Action Dinámico -->
      <a
        href={hasBoveda ? bovedaUrl : formUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-shrink-0 inline-flex items-center justify-center gap-2 bg-gray-900 hover:bg-gray-700 text-white font-semibold px-7 py-3 rounded-lg transition-colors duration-200 active:scale-95 w-full lg:w-auto text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.75 3.75 0 0118 19.5H6.75z" />
        </svg>
        {hasBoveda ? "Abrir Repositorio Completo" : "Aportar Nuevo Software"}
      </a>
    </div>
  </div>

  <!-- ══════════════════════ GRID DE SOFTWARE ══════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">

    <div class="mb-10">
      <p class="section-label mb-2">Herramientas Recomendadas</p>
      <h2 class="text-2xl font-bold text-gray-900">Catálogo de Software</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {software.map(sw => (
        <SoftwareCard
          titulo={sw.titulo}
          version={sw.version}
          descripcion={sw.descripcion}
          tipoIcono={sw.tipoIcono}
        />
      ))}
    </div>

    <!-- Aviso Legal / Académico -->
    <div class="mt-12 bg-amber-50 border border-amber-200 rounded-xl p-5 flex items-start gap-3">
      <div class="text-amber-500 flex-shrink-0 mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
      </div>
      <div>
        <h4 class="text-amber-800 font-semibold text-sm mb-1">Nota sobre Uso Académico</h4>
        <p class="text-amber-700 text-sm leading-relaxed">
          Las herramientas informáticas compiladas en esta bóveda son de uso estrictamente educativo y de investigación dentro de los laboratorios del núcleo Guarenas de la UNEXPO. Asegúrate de verificar las políticas de licencias educativas e institucionales antes de efectuar su descarga e instalación en equipos personales.
        </p>
      </div>
    </div>
  </section>

</Layout>
