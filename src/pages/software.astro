---
import Layout from '../layouts/Layout.astro';
import SoftwareCard from '../components/SoftwareCard.astro';
import { driveLinks } from '../data/driveLinks.js';

const software = [
  {
    titulo: 'SolidWorks',
    version: 'Versión 2019',
    descripcion: 'Software líder de diseño mecánico en 3D. Modelado de piezas, ensamblajes, simulación de esfuerzos de torsión y análisis cinemático lineal.',
    tipoIcono: 'cad' as const,
  },
  {
    titulo: 'MATLAB',
    version: 'Versión 2017a',
    descripcion: 'Entorno de computación numérica, visualización matricial de datos y programación modular. Indispensable para asignaturas de control y procesamiento de señales.',
    tipoIcono: 'simulacion' as const,
  },
  {
    titulo: 'Proteus',
    version: 'Versión 8.10',
    descripcion: 'Entorno de diseño y simulación interactiva de circuitos electrónicos, microcontroladores y ruteo avanzado de pistas para placas impresas (PCB).',
    tipoIcono: 'simulacion' as const,
  },
  {
    titulo: 'TIA Portal',
    version: 'Versión 15',
    descripcion: 'Plataforma integrada de automatización industrial de Siemens. Programación de controladores lógicos S7-1200/1500, HMI y redes industriales.',
    tipoIcono: 'plc' as const,
  },
  {
    titulo: 'FluidSIM',
    version: 'Versión actual',
    descripcion: 'Simulador dinámico para el diseño y verificación de esquemas de fluidos de potencia (sistemas neumáticos, electroneumáticos e hidráulicos).',
    tipoIcono: 'hidraulica' as const,
  },
];

// Obtener el enlace maestro si existe
const bovedaUrl = driveLinks["BovedaMaestra"] || '';
const hasBoveda = bovedaUrl !== '';

// URL alternativa de aportes
const formUrl = "https://docs.google.com/forms/d/e/1FAIpQLSeHMDuXRaP0Sbtz7nTnw9wXbWO9KD2s76qGtqps3enAL4-IcA/viewform?usp=publish-editor";
---

<Layout
  title="Software y Simuladores"
  description="Herramientas de software especializado, CAD, simulación de circuitos y automatización industrial para estudiantes de Ingeniería Mecatrónica UNEXPO."
>

  <!-- ══════════════════════ HERO CORTO ══════════════════════ -->
  <section class="relative overflow-hidden border-b border-white/5 py-14 bg-slate-950/40">
    <div class="absolute inset-0 engineering-grid opacity-30"></div>
    <div class="absolute -top-10 -right-10 w-72 h-72 bg-sky-500 rounded-full blur-[90px] opacity-10 pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-slate-400 text-xs sm:text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-white font-medium">Software y Simuladores</span>
      </nav>

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center flex-shrink-0 text-sky-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3" />
            </svg>
          </div>
          <div>
            <h1 class="text-3xl md:text-4xl font-extrabold text-white">Software y Simuladores</h1>
            <p class="text-slate-400 mt-1.5 text-sm sm:text-base">
              Entornos de cálculo, diseño en 3D, simulación electrónica y programación industrial.
            </p>
          </div>
        </div>

        <!-- Contador de herramientas -->
        <div class="bg-white/5 border border-white/10 rounded-2xl px-5 py-2.5 text-center flex-shrink-0">
          <p class="text-2xl font-black text-sky-400 leading-none">{software.length}</p>
          <p class="text-slate-500 text-[10px] font-bold uppercase tracking-wider mt-1">Soportados</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════ CATEGORÍAS ══════════════════════ -->
  <div class="border-b border-white/5 bg-slate-950/20 backdrop-blur-sm sticky top-16 sm:top-20 z-40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5">
      <div class="flex flex-wrap items-center gap-3 text-xs sm:text-sm">
        <span class="text-slate-500 font-bold">Líneas de Estudio:</span>
        <span class="bg-violet-500/10 text-violet-400 border border-violet-500/20 font-bold px-3 py-1 rounded-full">CAD / 3D</span>
        <span class="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 font-bold px-3 py-1 rounded-full">Simulación</span>
        <span class="bg-amber-500/10 text-amber-400 border border-amber-500/20 font-bold px-3 py-1 rounded-full">PLC / SCADA</span>
        <span class="bg-sky-500/10 text-sky-400 border border-sky-500/20 font-bold px-3 py-1 rounded-full">Fluida / Neumática</span>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ BANNER BÓVEDA MAESTRA ══════════════════════ -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">
    <div class="glass-card rounded-3xl p-8 sm:p-10 flex flex-col lg:flex-row items-center justify-between gap-8 relative overflow-hidden group">
      
      <!-- Glow trasero sutil -->
      <div class="absolute top-0 right-0 w-72 h-72 bg-sky-500 rounded-full blur-[100px] opacity-10 pointer-events-none group-hover:opacity-15 transition-opacity duration-700"></div>
      
      <div class="relative z-10 flex items-start gap-5">
        <!-- Ícono de Nube -->
        <div class="w-14 h-14 bg-white/5 rounded-2xl flex items-center justify-center flex-shrink-0 text-sky-400 border border-white/10 shadow-inner">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
          </svg>
        </div>
        <div>
          <h2 class="text-xl sm:text-2xl font-extrabold text-white mb-2">Bóveda Maestra de Recursos de Software</h2>
          <p class="text-slate-400 text-sm leading-relaxed max-w-xl">
            ¿Requieres librerías adicionales, manuales oficiales de simulación o versiones complementarias? Explora el archivo principal del repositorio estudiantil.
          </p>
        </div>
      </div>
      
      <!-- Call to Action Dinámico -->
      <a 
        href={hasBoveda ? bovedaUrl : formUrl} 
        target="_blank" 
        rel="noopener noreferrer"
        class="relative z-10 flex-shrink-0 inline-flex items-center justify-center gap-2 bg-gradient-to-r from-sky-500 to-unexpo-blue hover:from-sky-400 hover:to-unexpo-blue-light text-white font-bold px-8 py-4 rounded-xl transition-all duration-300 shadow-md shadow-sky-500/10 hover:shadow-sky-500/25 active:scale-95 w-full lg:w-auto"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.75 3.75 0 0118 19.5H6.75z" />
        </svg>
        {hasBoveda ? "Abrir Repositorio Completo ↗" : "Aportar Nuevo Software ↗"}
      </a>
    </div>
  </div>

  <!-- ══════════════════════ GRID DE SOFTWARE ══════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">

    <div class="mb-10 text-center sm:text-left">
      <p class="text-sky-400 font-extrabold text-xs uppercase tracking-widest mb-2">Herramientas Recomendadas</p>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white">Catálogo de Software</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {software.map(sw => (
        <SoftwareCard
          titulo={sw.titulo}
          version={sw.version}
          descripcion={sw.descripcion}
          tipoIcono={sw.tipoIcono}
        />
      ))}
    </div>

    <!-- Aviso Legal / Académico -->
    <div class="mt-14 bg-amber-500/5 border border-amber-500/10 rounded-2xl p-6 flex items-start gap-4">
      <div class="text-amber-400 flex-shrink-0 mt-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5.5 h-5.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm leading-none mb-1">Nota sobre Uso Académico</h4>
        <p class="text-slate-400 text-sm leading-relaxed mt-1">
          Las herramientas informáticas compiladas en esta bóveda son de uso estrictamente educativo y de investigación dentro de los laboratorios del núcleo Guarenas de la UNEXPO. Asegúrate de verificar las políticas de licencias educativas e institucionales antes de efectuar su descarga e instalación en equipos personales.
        </p>
      </div>
    </div>
  </section>

</Layout>
